<?xml version="1.0" encoding="UTF-8"?>
<config>
    <application id="incidents_nucleaires"
        title="Incidents nucléaires déclarés"
        mouseposition="false"
        logo="apps/incidents_nucleaires/icon_map.png"
        help="apps/incidents_nucleaires/help.html"
        measuretools="true"
        exportpng="true"
        geoloc="true"
        style="apps/incidents_nucleaires/css/theme.css"
        templaterightinfopanel="brut"
        togglealllayersfromtheme="true"/>
    <mapoptions projection="EPSG:3857"
        maxzoom="19"
        zoom="6"
        center="310640.0829509563, 5907053.545878422"
        projextent="-20037508.342789244, -20037508.342789244, 20037508.342789244, 20037508.342789244" />

    <baselayers style="gallery">
        <baselayer type="OSM" id="positron" label="Positron" title="Carto"
            thumbgallery="img/basemap/positron.png"
            url="https://{a-c}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png"
            maxzoom="20"
            visible="true"
            attribution="Map tiles by &lt;a href='https://carto.com/attributions' target='_blank'>Carto&lt;/a>, under &lt;a href='https://creativecommons.org/licenses/by/3.0/' target='_blank'>CC BY 3.0&lt;/a>" />
    </baselayers>

    <proxy url=""/>
    <olscompletion url="https://api-adresse.data.gouv.fr/search/" type="ban" attribution="La recherche d'adresse est un service proposé par la BAN"/>
    <searchparameters bbox="false" localities="true" features="false" />

    <themes>
        <theme name="Incidents nucléaires" collapsed="false" id="incidents" icon="fas fa-radiation">
            <layer id="incidents_nucleaires"
                name="Incidents déclarés"
                visible="true"
                type="geojson"
                url="apps/incidents_nucleaires/data/incidents_nucleaires.geojson"
                searchable="false"
                queryable="true"
                tooltip="true"
                tooltipcontent="{{nom_site}} — INES {{niveau_ines}}"
                legendurl="apps/incidents_nucleaires/lgd_incidents.png"
                attribution="Sources : ASNR, référentiel local"
                style="apps/incidents_nucleaires/customlayer/incidents_nucleaires_style.js">
                <template url="apps/incidents_nucleaires/templates/incidents_nucleaires.mst"/>
            </layer>
        </theme>
    </themes>
</config>
